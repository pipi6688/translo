{
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(pnpm vitest *)",
      "Bash(pnpm compile)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(rm *.ts)",
      "Bash(rm *.tsx)",
      "Bash(rm *.css)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git reset --hard *)",
      "Bash(git push --force *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(echo \"$TOOL_INPUT\" | jq -r '.file_path // empty'); if [[ \"$FILE\" == *.test.ts || \"$FILE\" == *.test.tsx ]]; then cd /Users/siyiding/claw/claw-translate && pnpm vitest run --reporter=verbose 2>&1 | tail -20; fi"
          }
        ]
      }
    ]
  }
}
